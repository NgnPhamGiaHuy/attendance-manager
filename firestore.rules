rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    // Get the caller's role in a class from the members subcollection
    function getRole(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)/members/$(request.auth.uid)).data.role;
    }

    function isTeacher(classId) {
      return isAuthenticated() && getRole(classId) == "teacher";
    }

    function isTeacherOrTA(classId) {
      return isAuthenticated() && getRole(classId) in ["teacher", "ta"];
    }

    function isClassMember(classId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/classes/$(classId)/members/$(request.auth.uid));
    }

    // ─── Users Collection ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Classes Collection ────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isClassMember(classId);
      allow create: if isAuthenticated();
      // Teacher can update anything; TA cannot touch statusDefinitions, scoringRules, name, description, isArchived
      allow update: if isTeacher(classId) ||
        (isTeacherOrTA(classId) &&
         !("statusDefinitions" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("scoringRules" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("name" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("description" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("isArchived" in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isTeacher(classId);

      match /members/{userId} {
        allow read: if isClassMember(classId);
        allow write: if isTeacher(classId);
      }
    }

    // ─── Enrollments Collection ────────────────────────────────────────────
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Teacher/TA can update (deactivate); Cloud Functions use admin SDK (bypasses rules)
      allow update: if isTeacherOrTA(resource.data.classId) ||
        request.auth.token.firebase.sign_in_provider == "custom";
      allow delete: if false; // No hard deletes
    }

    // ─── Sessions Collection ───────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      // Teacher or TA can create/update; teacher-only delete
      allow create: if isAuthenticated() && isTeacherOrTA(request.resource.data.classId);
      allow update: if isAuthenticated() && isTeacherOrTA(resource.data.classId);
      allow delete: if isTeacher(resource.data.classId);
    }

    // ─── Attendance Records Collection ─────────────────────────────────────
    match /attendance_records/{recordId} {
      allow read: if isAuthenticated();
      
      // Teacher/TA can write; students can self-check-in via QR
      allow create: if isTeacherOrTA(request.resource.data.classId) ||
        // QR self-check-in: student can only create their own record
        (isClassMember(request.resource.data.classId) &&
         request.resource.data.studentId == request.auth.uid &&
         request.resource.data.source == "qr");
      
      allow update: if isTeacherOrTA(resource.data.classId);
      allow delete: if false; // No hard deletes
    }

    // ─── Analytics Aggregates Collection ───────────────────────────────────
    match /analytics_aggregates/{aggregateId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
  }
}
